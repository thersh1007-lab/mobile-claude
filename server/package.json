{
  "name": "mobile-claude",
  "version": "1.5.1",
  "description": "Chat with Claude AI from your phone with full dev environment access",
  "keywords": ["claude", "anthropic", "ai", "mobile", "pwa", "terminal", "claude-code", "developer-tools"],
  "author": "ATJ Digital",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thersh1007-lab/mobile-claude"
  },
  "bin": {
    "mobile-claude": "bin/cli.js"
  },
  "scripts": {
    "setup": "ts-node scripts/setup.ts",
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "test": "ts-node src/tests/integration.test.ts && ts-node src/tests/session-import.test.ts",
    "start": "node dist/index.js",
    "quickstart": "tsc && node dist/index.js",
    "prepublishOnly": "tsc"
  },
  "files": [
    "dist/",
    "public/",
    "scripts/",
    "bin/",
    "tsconfig.json",
    "package.json"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^6.27.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.0",
    "@types/ws": "^8.5.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
